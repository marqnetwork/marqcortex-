# Copy to .env.local and fill in your Supabase project values.
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

# Project URL (e.g. https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=

# Publishable key from Supabase Dashboard → API (sb_publishable_* or legacy anon JWT)
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=

# Optional: project ref if you prefer not to paste the full URL
# VITE_SUPABASE_PROJECT_ID=

# Edge function name (default matches Figma Make deploy)
# VITE_SUPABASE_EDGE_FUNCTION=make-server-324f4fbe

# Backend integration.
#   Production builds (deployed app) default to TRUE — real users persist to
#   Supabase. Local dev defaults to FALSE (demo mode). Set explicitly to override:
#     true  → force the real Supabase backend
#     false → force demo mode (localStorage only)
# Leave UNSET in production to get the real backend by default.
# VITE_BACKEND_INTEGRATION=true

# Dev helpers
# VITE_SHOW_API_ERRORS=true
# VITE_VERBOSE_LOGGING=true
# VITE_API_TIMEOUT=30000
