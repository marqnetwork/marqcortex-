# Copy to .env.local and fill in your Supabase project values.
# Current project (cortex): https://oqybniefkbppptfatoae.supabase.co
# Dashboard: https://supabase.com/dashboard/project/oqybniefkbppptfatoae/settings/api

# Project URL
VITE_SUPABASE_URL=https://oqybniefkbppptfatoae.supabase.co

# Publishable key from Supabase Dashboard → API (sb_publishable_* or legacy anon JWT)
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=

# Optional: project ref if you prefer not to paste the full URL
# VITE_SUPABASE_PROJECT_ID=

# Edge function name (default matches Figma Make deploy)
# VITE_SUPABASE_EDGE_FUNCTION=make-server-324f4fbe

# Flip to true once the edge function is deployed and reachable
VITE_BACKEND_INTEGRATION=false

# Dev helpers
# VITE_SHOW_API_ERRORS=true
# VITE_VERBOSE_LOGGING=true
# VITE_API_TIMEOUT=30000

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE SECRETS (Supabase → Edge Functions → Secrets, NOT the frontend .env)
# These are read by the edge function via Deno.env and must never be VITE_* exposed.
# ─────────────────────────────────────────────────────────────────────────────
# Seed a real team admin. Admin seeding is skipped entirely unless one of the two
# below is provided — no built-in password is ever created in production.
# TEAM_ADMIN_EMAIL=admin@yourdomain.com
# TEAM_ADMIN_PASSWORD=<strong-unique-password>
# TEAM_ADMIN_NAME=MARQ Admin
# ALLOW_DEMO_ADMIN=true      # local/demo ONLY — permits the built-in demo admin fallback
#
# CORS lockdown: comma-separated exact origins. When set, only these origins are
# allowed and credentialed CORS is enabled. When unset, CORS falls back to '*'
# without credentials (Bearer-token auth).
# ALLOWED_ORIGINS=https://app.marqcortex.com,https://marqcortex.com
